rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── HACKATHON MODE: Allow all authenticated users full access ──
    // TODO: Tighten these rules for production!
    
    match /products/{id} {
      allow read, write: if isAuth();
    }

    match /categories/{id} {
      allow read, write: if isAuth();
    }

    match /orders/{id} {
      allow read, write: if isAuth();
    }

    match /customers/{id} {
      allow read, write: if isAuth();
    }

    match /reviews/{id} {
      allow read, write: if isAuth();
    }

    match /promotions/{id} {
      allow read, write: if isAuth();
    }

    match /staff/{id} {
      allow read, write: if isAuth();
    }

    match /analytics_config/{id} {
      allow read, write: if isAuth();
    }

    // Settings: any authenticated user can read/write their own
    match /settings/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read: if isAuth(); // Allow reading others for admin features
    }
  }
}
